# GitHub API Configuration
# Create token at: https://github.com/settings/tokens
# Required scopes: public_repo (read public repositories only)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=vijay12968

# LinkedIn API (Future - Not yet implemented)
LINKEDIN_TOKEN=xxxxxxxxxxxxxxxxxxxxx

# Vercel Deployment (for CI/CD)
VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxxx

# Environment
NEXT_PUBLIC_ENV=development

# Cache Configuration
CACHE_TTL=86400  # 24 hours in seconds
CACHE_DIR=.cache

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=60000  # 1 minute
RATE_LIMIT_MAX_REQUESTS=100  # Max requests per window
