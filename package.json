{
  "name": "veeraj-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --watch",
    "test:ci": "jest --coverage",
    "refresh:github": "node scripts/refresh-github.js",
    "refresh:all": "npm run refresh:github",
    "clean": "rm -rf .next .cache",
    "clean:cache": "rm -rf .cache",
    "perf:lighthouse": "lhci autorun --config=tests/lighthouse-test.js",
    "perf:load": "k6 run tests/load-test.js",
    "perf:analyze": "npm run build && npx @next/bundle-analyzer",
    "perf:all": "npm run perf:lighthouse && npm run perf:load"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "next": "^14.2.35",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.1.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1"
  }
}
